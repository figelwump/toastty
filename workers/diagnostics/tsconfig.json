{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["@cloudflare/vitest-pool-workers/types"]
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "worker-configuration.d.ts", "../../Shared/**/*.json"]
}
